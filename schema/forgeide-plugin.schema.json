{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://forgeide.com/schema/plugin/v1",
  "title": "ForgeIDE Plugin Manifest",
  "description": "Schema for forgeide-plugin.json — the manifest file for ForgeIDE plugins",
  "type": "object",
  "required": ["id", "name", "version", "description", "author", "license", "engines", "capabilities", "entry_point", "min_forge_version"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:\\.[a-z0-9]+)+$",
      "description": "Reverse-DNS identifier, e.g. com.yourcompany.plugin-name"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver version, e.g. 1.0.0"
    },
    "description": {
      "type": "string",
      "maxLength": 280
    },
    "author": {
      "type": "string"
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier, e.g. MIT, Apache-2.0"
    },
    "engines": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["unity", "unreal", "godot", "all"]
      },
      "minItems": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "filesystem:read",
          "filesystem:write",
          "network:local",
          "network:internet",
          "process:spawn",
          "kb:read",
          "kb:write",
          "ai:routing"
        ]
      }
    },
    "entry_point": {
      "type": "string",
      "pattern": "\\.wasm$",
      "description": "Path to the .wasm binary within the plugin package"
    },
    "signature": {
      "type": "string",
      "description": "Base64-encoded Ed25519 signature over manifest JSON (OTG Studio curated plugins only)"
    },
    "min_forge_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Minimum ForgeIDE version required, e.g. 1.0.0"
    }
  },
  "additionalProperties": false
}
